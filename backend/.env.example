ENVIRONMENT=development
DATABASE_URL=sqlite:///./dev.db

# Google AI Studio 에서 발급. 절대 git에 커밋하지 말 것.
GEMINI_API_KEY=
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash

# 운영 환경에서는 충분히 긴 랜덤 값으로 교체할 것 (예: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=
JWT_ALGORITHM=HS256

# 선택: YouTube Data API v3 키 (없으면 영상 추천 기능은 빈 목록 반환)
YOUTUBE_API_KEY=

# 배포 시 실제 도메인으로 교체. 각 OAuth 콘솔의 "리디렉션 URI"는
# {BACKEND_BASE_URL}/auth/oauth/{provider}/callback 형식으로 등록해야 한다.
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# Google Cloud Console > API 및 서비스 > 사용자 인증 정보 에서 OAuth 클라이언트 발급
# 리디렉션 URI: http://localhost:8000/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kakao Developers > 내 애플리케이션 > 카카오 로그인 에서 발급 (이메일 동의항목 활성화 필요)
# 리디렉션 URI: http://localhost:8000/auth/oauth/kakao/callback
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Naver Developers > 애플리케이션 등록 에서 발급
# 콜백 URL: http://localhost:8000/auth/oauth/naver/callback
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
