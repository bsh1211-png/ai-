ENVIRONMENT=development
DATABASE_URL=sqlite:///./dev.db

# Google AI Studio 에서 발급. 절대 git에 커밋하지 말 것.
GEMINI_API_KEY=
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash

# 운영 환경에서는 충분히 긴 랜덤 값으로 교체할 것 (예: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=
JWT_ALGORITHM=HS256

# 선택: YouTube Data API v3 키 (없으면 영상 추천 기능은 빈 목록 반환)
YOUTUBE_API_KEY=

# 배포 시 실제 도메인으로 교체. OAuth 콘솔의 "리디렉션 URI"는
# {BACKEND_BASE_URL}/auth/oauth/google/callback 형식으로 등록해야 한다.
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# 추가 허용 Origin (콤마 구분, 운영 시 Vercel 도메인 입력)
# EXTRA_ALLOWED_ORIGINS=https://swolemeter.vercel.app,https://your-custom-domain.com

# Google Cloud Console > API 및 서비스 > 사용자 인증 정보 에서 OAuth 클라이언트 발급
# 승인된 리디렉션 URI: {BACKEND_BASE_URL}/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase Storage (미설정 시 로컬 파일시스템 사용)
# Supabase 대시보드 > Settings > API 에서 확인
# service_role 키 사용 (anon 키 X — 버킷 생성/삭제 권한 필요)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=swolemeter-media
